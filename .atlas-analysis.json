  "keyFeatures": [
    "SQL linting with 25+ dialect support (BigQuery, Snowflake, dbt, PostgreSQL, T-SQL, etc.)",
    "Auto-fix mode to automatically correct most linting violations",
    "Jinja and dbt templating support for modern ELT pipelines",
    "Highly configurable rule engine with per-rule and per-dialect overrides",
    "Python API for programmatic SQL linting and parsing",
    "CLI with lint, fix, parse, format, and render commands",
    "Pre-commit hook and CI/CD integration support",
    "Plugin system for custom rules and templaters"
  ],
  "publicApiSurface": [
    "sqlfluff lint <path>",
    "sqlfluff fix <path>",
    "sqlfluff parse <path>",
    "sqlfluff format <path>",
    "sqlfluff render <path>",
    "sqlfluff dialects",
    "sqlfluff rules",
    "sqlfluff.api.lint(sql, dialect, rules)",
    "sqlfluff.api.fix(sql, dialect, rules)",
    "sqlfluff.api.parse(sql, dialect)",
    "FluffConfig.from_root(overrides)",
    "Linter(config)",
    "Rule_AL01 (aliasing rules)",
    "Rule_LT01 (layout rules)",
